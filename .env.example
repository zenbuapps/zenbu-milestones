# ============================================================================
# .env.example — zenbu-milestones 全端環境變數範本
# ============================================================================
# 用法：
#   1. 複製此檔為 `.env`（本地後端）或 `.env.local`（本地前端）
#   2. 正式部署時將對應變數填入部署平台的環境變數管理器（Railway / Render / Fly.io）
#   3. 此檔不含真實秘密，可安全 commit；真實 .env 已被 .gitignore 擋掉，絕不可 commit
#
# 架構對應：
#   - 後端 NestJS（未來 apps/api）→ 讀取前半段
#   - 前端 Vite（未來 apps/web）→ 只讀取 VITE_ 前綴那段
# ============================================================================


# ============================================================================
# SECTION 1 — 後端 NestJS（apps/api）
# ============================================================================

# ------- 執行環境 -------
NODE_ENV=development                          # development | production | test
PORT=3000                                     # NestJS listen port（本地與 Vite 5173 錯開）

# 前端公開 URL（用於 OAuth callback 回導、CORS 白名單、email link）
APP_BASE_URL=http://localhost:5173

# 後端公開 URL（前端呼叫的目標、Google OAuth callback 的 base）
API_BASE_URL=http://localhost:3000


# ------- 資料庫（PostgreSQL）-------
# 本地開發可用 Docker：docker run -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:16
# 正式部署：Railway PostgreSQL 外掛會自動注入 DATABASE_URL
DATABASE_URL=postgresql://postgres:dev@localhost:5432/zenbu_milestones


# ------- Google OAuth 2.0 -------
# 申請位置：https://console.cloud.google.com/apis/credentials
#   1. 建立 OAuth 2.0 Client ID（Web application）
#   2. Authorized redirect URIs 填：
#      - http://localhost:3000/api/auth/google/callback（本地）
#      - https://{正式域名}/api/auth/google/callback（正式）
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/google/callback


# ------- Session / Auth -------
# 至少 32 byte 強隨機；產生方法：node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-very-long-random-string-at-least-32-bytes

# Cookie 設定（生產環境務必開 HTTPS 並設 secure=true）
SESSION_COOKIE_DOMAIN=localhost               # 正式環境填你的 root domain
SESSION_COOKIE_SECURE=false                   # development 可 false；production 必 true


# ------- GitHub 代理（後端代呼 API）-------
# 組織名稱（未來若換 org 改這裡）
GITHUB_ORG=zenbuapps

# Fine-grained PAT，權限範圍：
#   Repository: All repositories in zenbuapps
#   Contents: Read
#   Issues: Read & Write       ★ 後端代建 issue 必須
#   Metadata: Read
# 申請位置：https://github.com/settings/personal-access-tokens/new
# 過期：建議 90 天，到期前輪替
ZENBU_ORG_WRITE_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------- Bunny CDN（V1 暫不實作附件上傳，但 env 先備齊）-------
# ⚠️ BUNNY_STORAGE_PASSWORD 先前在對話中明文出現視為已洩漏，務必在 Bunny 控制台 rotate
BUNNY_CDN_URL=https://git-action.b-cdn.net
BUNNY_STORAGE_HOST=sg.storage.bunnycdn.com
BUNNY_STORAGE_ZONE=git-action
BUNNY_STORAGE_PASSWORD=rotate-this-and-paste-new-value-here


# ------- 管理員 Bootstrap -------
# 第一次登入的使用者若 email 在此清單中，自動授予 role=admin
# 多個 email 以逗號分隔，不要空白
INITIAL_ADMIN_EMAILS=you@example.com,another-admin@example.com


# ------- CORS -------
# 允許前端 origin（逗號分隔）；本地開發 + 正式部署 URL 都要列
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://zenbuapps.github.io


# ============================================================================
# SECTION 2 — 前端 Vite（apps/web）
# ============================================================================
# 前端 .env.local 只需要以下 VITE_ 前綴變數
# 其他 secret 絕對不可有 VITE_ 前綴（否則會被打包進 bundle 外洩）

# 後端 API 的公開 URL（前端 fetch 目標）
# 本地：http://localhost:3000
# 正式：https://your-api.up.railway.app（Railway 部署後的 URL）
VITE_API_BASE_URL=http://localhost:3000


# ============================================================================
# 不該出現在此檔的內容（提醒）
# ============================================================================
# ❌ 真實密碼、token、client secret
# ❌ 個人 email（INITIAL_ADMIN_EMAILS 的範例除外，請改成自己的）
# ❌ 生產環境的 DATABASE_URL
# ❌ 任何帶 VITE_ 前綴的秘密值（會打包進前端 bundle）
