{
  "name": "zenbu-milestones-monorepo",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:shared": "pnpm --filter shared dev",
    "dev:all": "pnpm -r --parallel run dev",
    "build": "pnpm --filter shared build && pnpm -r --filter \"!shared\" run build",
    "build:shared": "pnpm --filter shared build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "preview": "pnpm --filter web preview",
    "typecheck": "pnpm -r run typecheck",
    "prisma:migrate:dev": "pnpm --filter api prisma:migrate:dev",
    "prisma:generate": "pnpm --filter api prisma:generate"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
